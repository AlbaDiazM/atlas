<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Atlas — Proyectos</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink: #1a1a2e;
    --ink-soft: #3d3d5c;
    --ink-ghost: #8888aa;
    --paper: #f4f1eb;
    --paper-warm: #ede8df;
    --paper-card: #faf8f4;
    --gold: #c8952a;
    --gold-light: #f0c060;
    --gold-pale: #fdf3dc;
    --red: #c0392b;
    --green: #27ae60;
    --blue: #2980b9;
    --shadow-card: 0 2px 20px rgba(26,26,46,0.08), 0 1px 4px rgba(26,26,46,0.05);
    --shadow-panel: 0 8px 40px rgba(26,26,46,0.12);
    --radius: 16px;
    --radius-sm: 10px;
  }

  html, body {
    height: 100%;
    font-family: 'DM Sans', sans-serif;
    background: var(--paper);
    color: var(--ink);
    overflow: hidden;
  }

  /* ── Layout ─────────────────────────────────────── */
  .app {
    display: flex;
    height: 100vh;
    height: 100dvh;
  }

  /* ── Sidebar ─────────────────────────────────────── */
  .sidebar {
    width: 300px;
    min-width: 300px;
    background: var(--ink);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }

  .sidebar::before {
    content: '';
    position: absolute;
    top: -60px; left: -60px;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(200,149,42,0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .sidebar-header {
    padding: 32px 24px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .app-logo {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.5px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-mark {
    width: 32px; height: 32px;
    background: var(--gold);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
  }

  .sidebar-subtitle {
    margin-top: 4px;
    font-size: 12px;
    color: var(--ink-ghost);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .sidebar-section-label {
    padding: 20px 24px 8px;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    font-weight: 500;
  }

  .project-list {
    flex: 1;
    overflow-y: auto;
    padding: 0 12px;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.1) transparent;
  }

  .project-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 12px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background 0.18s;
    margin-bottom: 2px;
    position: relative;
  }

  .project-item:hover { background: rgba(255,255,255,0.06); }
  .project-item.active { background: rgba(200,149,42,0.15); }
  .project-item.active .project-name { color: var(--gold-light); }

  .project-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .project-name {
    flex: 1;
    font-size: 14px;
    color: rgba(255,255,255,0.8);
    font-weight: 400;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .project-count {
    font-size: 11px;
    color: rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.07);
    padding: 2px 7px;
    border-radius: 20px;
    font-weight: 500;
  }

  .sidebar-data-actions {
    display: flex;
    gap: 6px;
    margin-top: 12px;
  }

  .btn-data {
    flex: 1;
    padding: 7px 10px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.55);
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 500;
    cursor: pointer;
    text-align: center;
    transition: all 0.15s;
    letter-spacing: 0.3px;
    display: block;
  }
  .btn-data:hover { background: rgba(255,255,255,0.12); color: #fff; }

  .btn-new-project {
    margin: 12px;
    padding: 12px 16px;
    background: rgba(200,149,42,0.12);
    border: 1px dashed rgba(200,149,42,0.35);
    border-radius: var(--radius-sm);
    color: var(--gold);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    display: flex; align-items: center; gap: 8px;
    transition: all 0.18s;
    width: calc(100% - 24px);
  }
  .btn-new-project:hover { background: rgba(200,149,42,0.2); }

  /* ── Main Panel ─────────────────────────────────── */
  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--paper);
  }

  .main-header {
    padding: 28px 36px 0;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }

  .project-title-area { flex: 1; }

  .project-title {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.1;
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 8px;
  }

  .project-progress-text {
    font-size: 13px;
    color: var(--ink-ghost);
    font-weight: 400;
  }

  .progress-bar-wrap {
    width: 120px;
    height: 4px;
    background: var(--paper-warm);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--gold), var(--gold-light));
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  .header-actions {
    display: flex;
    gap: 10px;
    align-items: center;
    padding-top: 4px;
  }

  .btn-icon {
    width: 40px; height: 40px;
    border-radius: var(--radius-sm);
    border: none;
    background: var(--paper-warm);
    color: var(--ink-soft);
    font-size: 18px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.18s;
  }
  .btn-icon:hover { background: var(--paper-card); color: var(--gold); box-shadow: var(--shadow-card); }

  /* ── Filter bar ─────────────────────────────────── */
  .filter-bar {
    display: flex;
    gap: 8px;
    padding: 20px 36px 0;
    align-items: center;
  }

  .filter-pill {
    padding: 6px 14px;
    border-radius: 20px;
    border: 1px solid var(--paper-warm);
    background: transparent;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-ghost);
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 0.3px;
  }
  .filter-pill.active {
    background: var(--ink);
    border-color: var(--ink);
    color: #fff;
  }
  .filter-pill:hover:not(.active) { border-color: var(--ink-ghost); color: var(--ink-soft); }

  /* ── Task Area ──────────────────────────────────── */
  .task-area {
    flex: 1;
    overflow-y: auto;
    padding: 20px 36px 32px;
    scrollbar-width: thin;
    scrollbar-color: var(--paper-warm) transparent;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 12px;
    color: var(--ink-ghost);
    font-size: 14px;
    text-align: center;
  }

  .empty-icon { font-size: 48px; opacity: 0.4; }

  /* ── Task Card ──────────────────────────────────── */
  .task-group { margin-bottom: 8px; }

  .task-card {
    background: var(--paper-card);
    border: 1px solid rgba(26,26,46,0.07);
    border-radius: var(--radius);
    padding: 16px 20px;
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 8px;
    cursor: pointer;
    transition: all 0.18s;
    box-shadow: var(--shadow-card);
    animation: slideIn 0.2s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .task-card:hover { transform: translateY(-1px); box-shadow: 0 6px 28px rgba(26,26,46,0.1); }
  .task-card.done { opacity: 0.55; }
  .task-card.done .task-text { text-decoration: line-through; color: var(--ink-ghost); }

  .task-checkbox {
    width: 22px; height: 22px;
    border-radius: 7px;
    border: 2px solid var(--paper-warm);
    flex-shrink: 0;
    margin-top: 1px;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.15s;
    cursor: pointer;
    font-size: 13px;
  }
  .task-checkbox.checked {
    background: var(--green);
    border-color: var(--green);
    color: #fff;
  }

  .task-body { flex: 1; min-width: 0; }

  .task-text {
    font-size: 15px;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.4;
    word-break: break-word;
  }

  .task-badges {
    display: flex;
    gap: 6px;
    margin-top: 8px;
    flex-wrap: wrap;
    align-items: center;
  }

  .badge {
    font-size: 10px;
    font-weight: 500;
    padding: 3px 8px;
    border-radius: 20px;
    letter-spacing: 0.3px;
  }

  .badge-priority-alta { background: #fdecea; color: var(--red); }
  .badge-priority-media { background: var(--gold-pale); color: var(--gold); }
  .badge-priority-baja { background: #e8f8f0; color: var(--green); }
  .badge-date { background: var(--paper-warm); color: var(--ink-soft); }

  .task-delete {
    width: 30px; height: 30px;
    border-radius: 8px;
    border: none;
    background: transparent;
    color: var(--ink-ghost);
    font-size: 16px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.15s;
    flex-shrink: 0;
    opacity: 0;
  }
  .task-card:hover .task-delete { opacity: 1; }
  .task-delete:hover { background: #fdecea; color: var(--red); }

  /* ── Add Task Bar ───────────────────────────────── */
  .add-task-bar {
    padding: 0 36px 24px;
  }

  .add-task-form {
    background: var(--paper-card);
    border: 1px solid rgba(26,26,46,0.09);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  .add-task-row {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .add-task-input {
    flex: 1;
    padding: 15px 20px;
    border: none;
    background: transparent;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    color: var(--ink);
    outline: none;
  }
  .add-task-input::placeholder { color: var(--ink-ghost); }

  .add-task-options {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 16px 0 0;
  }

  .option-select {
    padding: 6px 10px;
    border: 1px solid var(--paper-warm);
    border-radius: 8px;
    background: var(--paper);
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: var(--ink-soft);
    cursor: pointer;
    outline: none;
  }

  .btn-add-task {
    padding: 10px 20px;
    background: var(--ink);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }
  .btn-add-task:hover { background: var(--gold); }

  /* ── Modal ──────────────────────────────────────── */
  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(26,26,46,0.45);
    backdrop-filter: blur(6px);
    display: flex; align-items: center; justify-content: center;
    z-index: 100;
    opacity: 0; pointer-events: none;
    transition: opacity 0.2s;
  }
  .modal-overlay.open { opacity: 1; pointer-events: all; }

  .modal {
    background: var(--paper-card);
    border-radius: 20px;
    padding: 32px;
    width: 440px;
    max-width: 90vw;
    box-shadow: var(--shadow-panel);
    transform: translateY(12px) scale(0.97);
    transition: transform 0.2s ease;
  }
  .modal-overlay.open .modal { transform: none; }

  .modal-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 20px;
  }

  .form-field { margin-bottom: 16px; }

  .form-label {
    display: block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--ink-ghost);
    margin-bottom: 6px;
  }

  .form-input {
    width: 100%;
    padding: 11px 14px;
    border: 1px solid var(--paper-warm);
    border-radius: var(--radius-sm);
    background: var(--paper);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--ink);
    outline: none;
    transition: border 0.15s;
  }
  .form-input:focus { border-color: var(--gold); }

  .color-picker-row {
    display: flex; gap: 10px; flex-wrap: wrap;
  }

  .color-swatch {
    width: 28px; height: 28px;
    border-radius: 50%;
    cursor: pointer;
    border: 3px solid transparent;
    transition: border-color 0.15s;
  }
  .color-swatch.selected { border-color: var(--ink); }

  .modal-actions {
    display: flex; gap: 10px; justify-content: flex-end; margin-top: 24px;
  }

  .btn-cancel {
    padding: 10px 20px;
    border: 1px solid var(--paper-warm);
    border-radius: var(--radius-sm);
    background: transparent;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--ink-soft);
    cursor: pointer;
    transition: all 0.15s;
  }
  .btn-cancel:hover { background: var(--paper-warm); }

  .btn-confirm {
    padding: 10px 24px;
    border: none;
    border-radius: var(--radius-sm);
    background: var(--ink);
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-confirm:hover { background: var(--gold); }

  /* ── Welcome state ──────────────────────────────── */
  .welcome-panel {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 40px;
    text-align: center;
  }

  .welcome-icon { font-size: 56px; }

  .welcome-title {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    color: var(--ink);
    font-weight: 700;
  }

  .welcome-text {
    font-size: 15px;
    color: var(--ink-ghost);
    max-width: 320px;
    line-height: 1.6;
  }

  .btn-welcome {
    margin-top: 8px;
    padding: 14px 28px;
    background: var(--ink);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-welcome:hover { background: var(--gold); }

  /* ── Scrollbar ──────────────────────────────────── */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(26,26,46,0.12); border-radius: 2px; }

  /* ── Portrait / Vertical Mode ───────────────────── */
  @media (orientation: portrait), (max-width: 820px) {

    html, body { overflow: hidden; }

    .app { flex-direction: column; }

    .sidebar {
      width: 100%;
      min-width: unset;
      height: auto;
      flex-direction: column;
    }

    .sidebar-header {
      padding: 52px 20px 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }

    .sidebar-subtitle { display: none; }
    .sidebar-section-label { display: none; }

    .project-list {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      overflow-y: hidden;
      padding: 10px 12px 12px;
      gap: 8px;
      scrollbar-width: none;
      flex: unset;
    }
    .project-list::-webkit-scrollbar { display: none; }

    .project-item {
      flex-shrink: 0;
      flex-direction: row;
      padding: 8px 14px;
      border-radius: 20px;
      margin-bottom: 0;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      width: auto;
    }
    .project-item.active {
      background: rgba(200,149,42,0.2);
      border-color: rgba(200,149,42,0.4);
    }
    .project-name {
      font-size: 13px;
      white-space: nowrap;
      overflow: visible;
      text-overflow: unset;
      max-width: 140px;
    }

    .btn-new-project {
      flex-shrink: 0;
      width: auto;
      margin: 0 4px 2px 4px;
      padding: 8px 14px;
      border-radius: 20px;
      white-space: nowrap;
      align-self: center;
    }

    .main { flex: 1; overflow: hidden; }

    .main-header { padding: 16px 18px 0; }
    .project-title { font-size: 22px; }
    .project-meta { gap: 10px; flex-wrap: wrap; }
    .progress-bar-wrap { width: 80px; }

    .filter-bar { padding: 12px 18px 0; gap: 6px; }
    .filter-pill { padding: 5px 12px; font-size: 11px; }

    .task-area { padding: 14px 18px 20px; }
    .task-card { padding: 14px 14px; }
    .task-delete { opacity: 1; }

    .add-task-bar { padding: 0 18px 20px; }
    .add-task-input { padding: 13px 16px; font-size: 14px; }
    .add-task-options { padding: 0 8px 0 0; }

    .modal { width: 92vw; padding: 24px 20px; }
    .modal-title { font-size: 20px; }
  }
</style>
</head>
<body>

<div class="app">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-header">
      <div class="app-logo">
        <span class="logo-mark">◈</span> Atlas
      </div>
      <div class="sidebar-subtitle">Gestor de Proyectos</div>
      <div class="sidebar-data-actions">
        <button class="btn-data" onclick="exportData()">↑ Exportar</button>
        <label class="btn-data btn-import">
          ↓ Importar
          <input type="file" accept=".json" onchange="importData(event)" style="display:none">
        </label>
      </div>
    </div>

    <div class="sidebar-section-label">Proyectos</div>
    <div class="project-list" id="projectList"></div>

    <button class="btn-new-project" onclick="openNewProjectModal()">
      <span style="font-size:16px">＋</span> Nuevo Proyecto
    </button>
  </aside>

  <!-- MAIN -->
  <main class="main" id="mainPanel">
    <div class="welcome-panel">
      <div class="welcome-icon">🗂️</div>
      <div class="welcome-title">Bienvenido a Atlas</div>
      <div class="welcome-text">Organiza tus proyectos y desglósalos en tareas concretas. Empieza creando tu primer proyecto.</div>
      <button class="btn-welcome" onclick="openNewProjectModal()">Crear primer proyecto</button>
    </div>
  </main>
</div>

<!-- MODAL NUEVO PROYECTO -->
<div class="modal-overlay" id="projectModal">
  <div class="modal">
    <div class="modal-title">Nuevo Proyecto</div>
    <div class="form-field">
      <label class="form-label">Nombre del Proyecto</label>
      <input class="form-input" id="newProjectName" placeholder="Ej: Rediseño de sitio web" maxlength="60">
    </div>
    <div class="form-field">
      <label class="form-label">Color</label>
      <div class="color-picker-row" id="colorPicker"></div>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal('projectModal')">Cancelar</button>
      <button class="btn-confirm" onclick="createProject()">Crear Proyecto</button>
    </div>
  </div>
</div>

<script>
// ── State ────────────────────────────────────────────
const COLORS = ['#e74c3c','#e67e22','#f1c40f','#27ae60','#1abc9c','#3498db','#9b59b6','#e91e63','#607d8b','#c8952a'];
let selectedColor = COLORS[5];
let projects = [];
let activeProjectId = null;
let activeFilter = 'todas';

// ── Persistence ──────────────────────────────────────
function save() { localStorage.setItem('atlas_data', JSON.stringify(projects)); }
function load() {
  try { projects = JSON.parse(localStorage.getItem('atlas_data')) || []; } catch { projects = []; }
}

// ── Init ─────────────────────────────────────────────
load();
renderColorPicker();
renderSidebar();
if (projects.length > 0) selectProject(projects[0].id);

// ── Color Picker ─────────────────────────────────────
function renderColorPicker() {
  const el = document.getElementById('colorPicker');
  el.innerHTML = COLORS.map(c =>
    `<div class="color-swatch${c===selectedColor?' selected':''}" style="background:${c}" onclick="selectColor('${c}')"></div>`
  ).join('');
}

function selectColor(c) {
  selectedColor = c;
  renderColorPicker();
}

// ── Sidebar ───────────────────────────────────────────
function renderSidebar() {
  const el = document.getElementById('projectList');
  if (!projects.length) { el.innerHTML = ''; return; }
  el.innerHTML = projects.map(p => {
    const done = p.tasks.filter(t => t.done).length;
    const total = p.tasks.length;
    return `
      <div class="project-item${p.id===activeProjectId?' active':''}" onclick="selectProject('${p.id}')">
        <div class="project-dot" style="background:${p.color}"></div>
        <span class="project-name">${escHtml(p.name)}</span>
        <span class="project-count">${done}/${total}</span>
      </div>`;
  }).join('');
}

// ── Project CRUD ──────────────────────────────────────
function openNewProjectModal() {
  selectedColor = COLORS[Math.floor(Math.random()*COLORS.length)];
  renderColorPicker();
  document.getElementById('newProjectName').value = '';
  openModal('projectModal');
  setTimeout(()=>document.getElementById('newProjectName').focus(),200);
}

function createProject() {
  const name = document.getElementById('newProjectName').value.trim();
  if (!name) { document.getElementById('newProjectName').focus(); return; }
  const project = { id: uid(), name, color: selectedColor, tasks: [], created: Date.now() };
  projects.unshift(project);
  save();
  closeModal('projectModal');
  renderSidebar();
  selectProject(project.id);
}

// ── Select Project ────────────────────────────────────
function selectProject(id) {
  activeProjectId = id;
  activeFilter = 'todas';
  renderSidebar();
  renderMain();
}

// ── Main Panel ────────────────────────────────────────
function renderMain() {
  const project = projects.find(p => p.id === activeProjectId);
  if (!project) return;

  const total = project.tasks.length;
  const done = project.tasks.filter(t => t.done).length;
  const pct = total ? Math.round((done/total)*100) : 0;

  let filtered = project.tasks;
  if (activeFilter === 'pendientes') filtered = filtered.filter(t => !t.done);
  if (activeFilter === 'completadas') filtered = filtered.filter(t => t.done);

  document.getElementById('mainPanel').innerHTML = `
    <div class="main-header">
      <div class="project-title-area">
        <div class="project-title">${escHtml(project.name)}</div>
        <div class="project-meta">
          <span class="project-progress-text">${done} de ${total} tareas completadas</span>
          <div class="progress-bar-wrap">
            <div class="progress-bar-fill" style="width:${pct}%"></div>
          </div>
          <span class="project-progress-text" style="color:var(--gold);font-weight:500">${pct}%</span>
        </div>
      </div>
      <div class="header-actions">
        <button class="btn-icon" title="Eliminar proyecto" onclick="deleteProject('${project.id}')">🗑</button>
      </div>
    </div>

    <div class="filter-bar">
      <button class="filter-pill${activeFilter==='todas'?' active':''}" onclick="setFilter('todas')">Todas</button>
      <button class="filter-pill${activeFilter==='pendientes'?' active':''}" onclick="setFilter('pendientes')">Pendientes</button>
      <button class="filter-pill${activeFilter==='completadas'?' active':''}" onclick="setFilter('completadas')">Completadas</button>
    </div>

    <div class="task-area" id="taskArea">
      ${renderTasks(filtered, project)}
    </div>

    <div class="add-task-bar">
      <div class="add-task-form">
        <div class="add-task-row">
          <input class="add-task-input" id="newTaskInput" placeholder="Añadir nueva tarea…" maxlength="200"
            onkeydown="if(event.key==='Enter') addTask('${project.id}')">
          <div class="add-task-options">
            <select class="option-select" id="taskPriority">
              <option value="media">⚡ Media</option>
              <option value="alta">🔴 Alta</option>
              <option value="baja">🟢 Baja</option>
            </select>
          </div>
          <div style="padding:8px 12px 8px 0">
            <button class="btn-add-task" onclick="addTask('${project.id}')">Agregar</button>
          </div>
        </div>
      </div>
    </div>
  `;
  setTimeout(()=>{ const i=document.getElementById('newTaskInput'); if(i) i.focus(); },50);
}

function renderTasks(tasks, project) {
  if (!tasks.length) {
    return `<div class="empty-state">
      <div class="empty-icon">✦</div>
      <div style="font-family:'Playfair Display',serif;font-size:18px;color:var(--ink-soft)">Sin tareas aquí</div>
      <div>Agrega la primera tarea de este proyecto</div>
    </div>`;
  }

  return tasks.map(t => `
    <div class="task-card${t.done?' done':''}" id="task-${t.id}">
      <div class="task-checkbox${t.done?' checked':''}" onclick="toggleTask('${project.id}','${t.id}')">
        ${t.done?'✓':''}
      </div>
      <div class="task-body">
        <div class="task-text">${escHtml(t.text)}</div>
        <div class="task-badges">
          <span class="badge badge-priority-${t.priority}">${priorityLabel(t.priority)}</span>
          <span class="badge badge-date">${formatDate(t.created)}</span>
        </div>
      </div>
      <button class="task-delete" onclick="deleteTask('${project.id}','${t.id}')" title="Eliminar">×</button>
    </div>
  `).join('');
}

// ── Task CRUD ─────────────────────────────────────────
function addTask(projectId) {
  const input = document.getElementById('newTaskInput');
  const text = input.value.trim();
  if (!text) { input.focus(); return; }
  const priority = document.getElementById('taskPriority').value;
  const project = projects.find(p => p.id === projectId);
  project.tasks.unshift({ id: uid(), text, priority, done: false, created: Date.now() });
  save();
  input.value = '';
  input.focus();
  renderMain();
  renderSidebar();
}

function toggleTask(projectId, taskId) {
  const project = projects.find(p => p.id === projectId);
  const task = project.tasks.find(t => t.id === taskId);
  task.done = !task.done;
  save();
  renderMain();
  renderSidebar();
}

function deleteTask(projectId, taskId) {
  const project = projects.find(p => p.id === projectId);
  project.tasks = project.tasks.filter(t => t.id !== taskId);
  save();
  renderMain();
  renderSidebar();
}

function deleteProject(projectId) {
  if (!confirm('¿Eliminar este proyecto y todas sus tareas?')) return;
  projects = projects.filter(p => p.id !== projectId);
  activeProjectId = projects.length ? projects[0].id : null;
  save();
  renderSidebar();
  if (activeProjectId) renderMain();
  else {
    document.getElementById('mainPanel').innerHTML = `
      <div class="welcome-panel">
        <div class="welcome-icon">🗂️</div>
        <div class="welcome-title">Sin Proyectos</div>
        <div class="welcome-text">Crea un nuevo proyecto para empezar a organizar tus tareas.</div>
        <button class="btn-welcome" onclick="openNewProjectModal()">Crear Proyecto</button>
      </div>`;
  }
}

// ── Filters ───────────────────────────────────────────
function setFilter(f) {
  activeFilter = f;
  renderMain();
}

// ── Modal helpers ─────────────────────────────────────
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

document.querySelectorAll('.modal-overlay').forEach(el => {
  el.addEventListener('click', e => { if (e.target === el) closeModal(el.id); });
});

// ── Keyboard shortcut ─────────────────────────────────
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.querySelectorAll('.modal-overlay.open').forEach(el=>closeModal(el.id));
});

// ── Export / Import ───────────────────────────────────
function exportData() {
  const data = { version: 1, exported: new Date().toISOString(), projects };
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  const fecha = new Date().toLocaleDateString('es-MX', { year:'numeric', month:'2-digit', day:'2-digit' }).replace(/\//g,'-');
  a.href = url;
  a.download = `atlas-backup-${fecha}.json`;
  a.click();
  URL.revokeObjectURL(url);
}

function importData(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const data = JSON.parse(e.target.result);
      const imported = data.projects || (Array.isArray(data) ? data : null);
      if (!imported) { alert('Archivo no válido. Asegúrate de usar un backup de Atlas.'); return; }
      if (projects.length > 0) {
        const merge = confirm(`¿Qué quieres hacer con los datos actuales?\n\nAceptar → Combinar (conserva los proyectos actuales y agrega los importados)\nCancelar → Reemplazar (borra todo y usa solo los importados)`);
        if (merge) {
          // Merge: add imported projects that don't already exist by id
          const existingIds = new Set(projects.map(p => p.id));
          const newOnes = imported.filter(p => !existingIds.has(p.id));
          projects = [...projects, ...newOnes];
          alert(`Se agregaron ${newOnes.length} proyecto(s) nuevo(s).`);
        } else {
          projects = imported;
          alert(`Datos reemplazados. ${projects.length} proyecto(s) cargados.`);
        }
      } else {
        projects = imported;
      }
      activeProjectId = projects.length ? projects[0].id : null;
      save();
      renderSidebar();
      if (activeProjectId) renderMain(); else showWelcome();
    } catch {
      alert('Error al leer el archivo. Asegúrate de que sea un backup válido de Atlas.');
    }
    event.target.value = '';
  };
  reader.readAsText(file);
}

function showWelcome() {
  document.getElementById('mainPanel').innerHTML = `
    <div class="welcome-panel">
      <div class="welcome-icon">🗂️</div>
      <div class="welcome-title">Sin Proyectos</div>
      <div class="welcome-text">Crea un nuevo proyecto para empezar a organizar tus tareas.</div>
      <button class="btn-welcome" onclick="openNewProjectModal()">Crear Proyecto</button>
    </div>`;
}

// ── Utils ─────────────────────────────────────────────
function uid() { return Math.random().toString(36).slice(2,10); }
function escHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function priorityLabel(p) {
  return { alta:'🔴 Alta', media:'⚡ Media', baja:'🟢 Baja' }[p] || p;
}
function formatDate(ts) {
  const d = new Date(ts);
  return d.toLocaleDateString('es-MX', { day:'numeric', month:'short' });
}
</script>
